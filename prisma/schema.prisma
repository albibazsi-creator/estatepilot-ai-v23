generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AGENT
  AGENCY_OWNER
  BUYER
  SELLER
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
  PANORAMA_360
  FLOORPLAN
}

enum TourType {
  MATTERPORT
  IFRAME
  PANORAMA_360
  CUSTOM_360
  GAUSSIAN_SPLAT
}

enum LeadStatus {
  NEW
  CONTACTED
  BOOKED
  OFFER
  LOST
  WON
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}


enum AiJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
}


enum TaskStatus {
  OPEN
  DONE
  SNOOZED
  CANCELLED
}

enum CampaignStatus {
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
}

enum CalendarSlotStatus {
  OPEN
  HELD
  BOOKED
  BLOCKED
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  passwordHash   String?
  authProviderId String?
  role           UserRole       @default(AGENT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  agencyMembers  AgencyMember[]
  listings       Listing[]      @relation("AgentListings")
  leads          Lead[]         @relation("AgentLeads")
  appointments   Appointment[]  @relation("AgentAppointments")
  followUpTasks  FollowUpTask[] @relation("AssignedTasks")
  calendarSlots  CalendarSlot[] @relation("AgentSlots")
}

model Agency {
  id               String         @id @default(cuid())
  name             String
  logoUrl          String?
  billingEmail     String?
  subscriptionPlan String?        @default("manual")
  createdAt        DateTime       @default(now())
  members          AgencyMember[]
  listings         Listing[]
  subscriptions    Subscription[]
  jobs             AiJob[]
  notifications    NotificationLog[]
  apiKeys          ApiKey[]
  webhookEvents    WebhookEvent[]
  marketingCampaigns MarketingCampaign[]
  integrations      Integration[]
}

model AgencyMember {
  id        String   @id @default(cuid())
  agencyId  String
  userId    String
  role      UserRole @default(AGENT)
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([agencyId, userId])
}

model Listing {
  id             String         @id @default(cuid())
  agencyId       String
  agentId        String
  title          String
  slug           String         @unique
  propertyType   String
  sellerName     String?
  sellerEmail    String?
  ownerReportEmail String?
  neighborhood   String?
  parking        String?
  balcony        String?
  heating        String?
  orientation    String?
  energyRating   String?
  latitude       Float?
  longitude      Float?
  currency       String         @default("HUF")
  aiReadinessScore Int          @default(0)
  status         ListingStatus  @default(DRAFT)
  city           String
  district       String?
  addressOptional String?
  price          Int?
  sizeM2         Float?
  rooms          Float?
  bedrooms       Int?
  bathrooms      Int?
  floor          String?
  condition      String?
  descriptionRaw String?
  descriptionAi  String?
  isPublished    Boolean        @default(false)
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  agency         Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agent          User           @relation("AgentListings", fields: [agentId], references: [id])
  media          ListingMedia[]
  tours          Tour[]
  floorplans     Floorplan[]
  aiOutputs      AiOutput[]
  leads          Lead[]
  leadEvents     LeadEvent[]
  appointments   Appointment[]
  sellerReports  SellerReport[]
  aiJobs         AiJob[]
  notifications  NotificationLog[]
  chatSessions   ChatSession[]
  marketingCampaigns MarketingCampaign[]
  followUpTasks  FollowUpTask[]
  calendarSlots  CalendarSlot[]
}

model ListingMedia {
  id                 String   @id @default(cuid())
  listingId          String
  mediaType          MediaType
  url                String
  originalUrl        String?
  thumbnailUrl       String?
  storageProvider    String   @default("local")
  storageKey         String?
  fileSizeBytes      Int?
  mimeType           String?
  width              Int?
  height             Int?
  processingStatus   String   @default("ready")
  roomLabel          String?
  aiTags             Json?
  qualityScore       Int?
  isCover            Boolean  @default(false)
  isStaged           Boolean  @default(false)
  disclosureRequired Boolean  @default(false)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  listing            Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Tour {
  id        String     @id @default(cuid())
  listingId String
  tourType  TourType
  provider  String?
  embedUrl  String?
  status    String     @default("ready")
  createdAt DateTime   @default(now())
  listing   Listing    @relation(fields: [listingId], references: [id], onDelete: Cascade)
  nodes     TourNode[]
  hotspots  TourHotspot[]
}

model TourNode {
  id          String   @id @default(cuid())
  tourId      String
  roomName    String
  panoramaUrl String?
  positionX   Float?
  positionY   Float?
  positionZ   Float?
  sortOrder   Int      @default(0)
  tour        Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  outgoing    TourHotspot[] @relation("FromNode")
  incoming    TourHotspot[] @relation("ToNode")
}

model TourHotspot {
  id         String   @id @default(cuid())
  tourId     String
  fromNodeId String
  toNodeId   String?
  label      String
  yaw        Float?
  pitch      Float?
  type       String   @default("room")
  tour       Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  fromNode   TourNode @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode     TourNode? @relation("ToNode", fields: [toNodeId], references: [id], onDelete: SetNull)
}

model Floorplan {
  id           String   @id @default(cuid())
  listingId    String
  fileUrl      String
  type         String   @default("upload")
  status       String   @default("ready")
  metadataJson Json?
  createdAt    DateTime @default(now())
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model AiOutput {
  id          String   @id @default(cuid())
  listingId   String
  outputType  String
  contentJson Json
  modelUsed   String?
  createdAt   DateTime @default(now())
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Lead {
  id            String       @id @default(cuid())
  listingId     String
  agentId       String
  name          String
  email         String?
  phone         String?
  message       String?
  buyingIntent  String?
  financingType String?
  moveTimeline  String?
  source        String       @default("public_listing")
  leadScore     Int          @default(0)
  aiSummary     String?
  lastContactedAt DateTime?
  nextFollowUpAt DateTime?
  gdprConsentAt DateTime?
  gdprSource    String?
  status        LeadStatus   @default(NEW)
  createdAt     DateTime     @default(now())
  listing       Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  agent         User         @relation("AgentLeads", fields: [agentId], references: [id])
  events        LeadEvent[]
  appointments  Appointment[]
  notifications NotificationLog[]
  chatSessions  ChatSession[]
  followUpTasks FollowUpTask[]
}

model LeadEvent {
  id           String   @id @default(cuid())
  leadId       String?
  listingId    String
  eventType    String
  metadataJson Json?
  createdAt    DateTime @default(now())
  lead         Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Appointment {
  id        String            @id @default(cuid())
  leadId    String
  listingId String
  agentId   String
  startTime DateTime
  endTime   DateTime
  status    AppointmentStatus @default(PENDING)
  createdAt DateTime          @default(now())
  lead      Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  listing   Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  agent     User              @relation("AgentAppointments", fields: [agentId], references: [id])
}

model SellerReport {
  id           String    @id @default(cuid())
  listingId    String
  periodStart  DateTime
  periodEnd    DateTime
  metricsJson  Json
  aiSummary    String
  sellerEmail  String?
  shareToken   String?   @unique
  status       String    @default("draft")
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  listing      Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                 String   @id @default(cuid())
  agencyId           String
  plan               String
  status             String
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  paymentProvider    String?
  createdAt          DateTime @default(now())
  agency             Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
}

model AiJob {
  id          String      @id @default(cuid())
  agencyId    String
  listingId   String?
  type        String
  status      AiJobStatus @default(PENDING)
  priority    Int         @default(50)
  payload     Json?
  result      Json?
  attempts    Int         @default(0)
  maxAttempts Int         @default(3)
  lockedAt    DateTime?
  finishedAt  DateTime?
  error       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  listing     Listing?    @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([status, priority, createdAt])
  @@index([agencyId, type])
}

model NotificationLog {
  id               String             @id @default(cuid())
  agencyId          String
  listingId         String?
  leadId            String?
  channel           String
  to                String
  subject           String?
  status            NotificationStatus @default(PENDING)
  payloadJson       Json?
  provider          String?
  providerResponse  Json?
  error             String?
  sentAt            DateTime?
  createdAt         DateTime           @default(now())
  agency            Agency             @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  listing           Listing?           @relation(fields: [listingId], references: [id], onDelete: SetNull)
  lead              Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([agencyId, status, createdAt])
}

model ApiKey {
  id          String   @id @default(cuid())
  agencyId    String
  name        String
  keyHash     String
  prefix      String
  scopes      String[]
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, prefix])
}

model WebhookEvent {
  id          String        @id @default(cuid())
  agencyId    String?
  provider    String
  eventType   String
  externalId  String?
  status      WebhookStatus @default(RECEIVED)
  payloadJson Json
  error       String?
  createdAt   DateTime      @default(now())
  processedAt DateTime?
  agency      Agency?       @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([provider, eventType, createdAt])
  @@unique([provider, externalId])
}



model ChatSession {
  id          String        @id @default(cuid())
  listingId   String
  leadId      String?
  visitorId   String?
  summary     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  listing     Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  lead        Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages    ChatMessage[]

  @@index([listingId, createdAt])
  @@index([leadId])
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  role        String
  content     String
  confidence  String?
  createdAt   DateTime    @default(now())
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model MarketingCampaign {
  id                    String         @id @default(cuid())
  agencyId              String
  listingId             String
  name                  String
  objective             String         @default("lead_generation")
  status                CampaignStatus @default(DRAFT)
  audienceJson          Json?
  assetsJson            Json?
  budgetSuggestionJson  Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  agency                Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  listing               Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([agencyId, status, createdAt])
  @@index([listingId])
}

model FollowUpTask {
  id              String      @id @default(cuid())
  listingId       String?
  leadId          String?
  assignedUserId  String?
  title           String
  description     String?
  priority        Int         @default(50)
  status          TaskStatus  @default(OPEN)
  dueAt           DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  listing         Listing?    @relation(fields: [listingId], references: [id], onDelete: Cascade)
  lead            Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedUser    User?       @relation("AssignedTasks", fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([assignedUserId, status, dueAt])
  @@index([listingId, status])
}

model CalendarSlot {
  id          String             @id @default(cuid())
  listingId   String?
  agentId     String
  startTime   DateTime
  endTime     DateTime
  status      CalendarSlotStatus @default(OPEN)
  note        String?
  createdAt   DateTime           @default(now())
  listing     Listing?           @relation(fields: [listingId], references: [id], onDelete: SetNull)
  agent       User               @relation("AgentSlots", fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, status, startTime])
  @@index([listingId, startTime])
}

model Integration {
  id           String   @id @default(cuid())
  agencyId     String
  provider     String
  type         String
  status       String   @default("mock")
  configJson   Json?
  connectedAt  DateTime?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  agency       Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, provider, type])
}


model UploadObject {
  id             String   @id @default(cuid())
  agencyId       String?
  listingId      String?
  provider       String
  storageKey     String
  publicUrl      String?
  mimeType       String?
  fileSizeBytes  Int?
  status         String   @default("created")
  checksum       String?
  metadataJson   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([agencyId, createdAt])
  @@index([listingId, createdAt])
  @@unique([provider, storageKey])
}

model BillingCustomer {
  id                 String   @id @default(cuid())
  agencyId           String
  provider           String
  externalCustomerId String?
  billingEmail       String?
  metadataJson       Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([agencyId, provider])
}

model PaymentRecord {
  id                  String   @id @default(cuid())
  agencyId            String
  listingId           String?
  provider            String
  externalPaymentId   String?
  checkoutUrl         String?
  plan                String
  amount              Int
  currency            String   @default("HUF")
  status              String   @default("created")
  metadataJson        Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([agencyId, status, createdAt])
  @@unique([provider, externalPaymentId])
}

model InvoiceRecord {
  id                  String   @id @default(cuid())
  agencyId            String
  paymentRecordId     String?
  provider            String   @default("szamlazzhu")
  externalInvoiceId   String?
  invoiceNumber       String?
  buyerName           String?
  buyerEmail          String?
  amount              Int
  currency            String   @default("HUF")
  status              String   @default("draft")
  pdfUrl              String?
  metadataJson        Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([agencyId, status, createdAt])
}

model CalendarConnection {
  id                   String   @id @default(cuid())
  agencyId             String
  userId               String
  provider             String   @default("google")
  externalAccountEmail String?
  status               String   @default("mock")
  accessTokenEncrypted String?
  refreshTokenEncrypted String?
  expiresAt            DateTime?
  metadataJson         Json?
  connectedAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([agencyId, userId, provider])
}

model AiTrace {
  id           String   @id @default(cuid())
  agencyId     String?
  listingId    String?
  operation    String
  model        String?
  provider     String   @default("openai")
  inputSummary String?
  outputSummary String?
  status       String   @default("success")
  latencyMs    Int?
  tokenUsageJson Json?
  error        String?
  createdAt    DateTime @default(now())

  @@index([agencyId, operation, createdAt])
  @@index([listingId, createdAt])
}


enum PortalExportStatus {
  DRAFT
  GENERATED
  DOWNLOADED
  SENT
  FAILED
}

model PortalExport {
  id             String             @id @default(cuid())
  agencyId       String
  listingId      String
  targetPortal   String
  status         PortalExportStatus @default(DRAFT)
  format         String             @default("json")
  fileUrl        String?
  payloadJson    Json
  validationJson Json?
  generatedById  String?
  generatedAt    DateTime?
  downloadedAt   DateTime?
  error          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([agencyId, targetPortal, createdAt])
  @@index([listingId, status])
}

model ConsentRecord {
  id            String    @id @default(cuid())
  agencyId      String?
  listingId     String?
  leadId        String?
  purpose       String
  subjectEmail  String?
  subjectPhone  String?
  source        String
  ipHash        String?
  userAgent     String?
  consentText   String
  acceptedAt    DateTime  @default(now())
  revokedAt     DateTime?
  metadataJson  Json?
  createdAt     DateTime  @default(now())

  @@index([agencyId, purpose, acceptedAt])
  @@index([leadId])
  @@index([subjectEmail])
}

model DataQualityIssue {
  id             String   @id @default(cuid())
  agencyId       String
  listingId      String?
  entityType     String
  entityId       String?
  severity       String
  code           String
  title          String
  description    String
  suggestedFix   String?
  status         String   @default("open")
  metadataJson   Json?
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?

  @@index([agencyId, severity, status, createdAt])
  @@index([listingId, status])
}

model FeatureFlag {
  id            String   @id @default(cuid())
  agencyId      String?
  key           String
  enabled       Boolean  @default(false)
  description   String?
  rolloutJson   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([agencyId, key])
  @@index([key, enabled])
}

model SecurityEvent {
  id            String   @id @default(cuid())
  agencyId      String?
  actorUserId   String?
  eventType     String
  severity      String   @default("info")
  ipHash        String?
  userAgent     String?
  metadataJson  Json?
  createdAt     DateTime @default(now())

  @@index([agencyId, severity, createdAt])
  @@index([eventType, createdAt])
}


// V8: agency/team, deal pipeline, proposal, valuation, seller activity, demo run, chat gap models.
model TeamInvite {
  id             String   @id @default(cuid())
  agencyId       String
  email          String
  role           String   @default("AGENT")
  status         String   @default("pending")
  invitedById    String?
  token          String   @unique
  expiresAt      DateTime?
  acceptedAt     DateTime?
  metadataJson   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([agencyId, status, createdAt])
  @@index([email])
}

model DealPipelineItem {
  id                  String   @id @default(cuid())
  agencyId            String
  listingId           String?
  leadId              String?
  ownerUserId         String?
  title               String
  stage               String   @default("new_lead")
  probability         Int      @default(10)
  forecastValue       Int      @default(0)
  currency            String   @default("HUF")
  expectedCloseDate   DateTime?
  nextStep            String?
  riskLevel           String   @default("medium")
  aiRecommendation    String?
  metadataJson        Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([agencyId, stage, probability])
  @@index([listingId])
  @@index([leadId])
}

model ProposalDraft {
  id               String   @id @default(cuid())
  agencyId         String
  listingId        String?
  leadId           String?
  dealId           String?
  title            String
  offerType        String   @default("viewing_followup")
  status           String   @default("draft")
  subject          String?
  bodyMarkdown     String
  callScript       String?
  nextActionsJson  Json?
  generatedById    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([agencyId, status, createdAt])
  @@index([listingId])
  @@index([leadId])
}

model SellerPortalActivity {
  id             String   @id @default(cuid())
  agencyId       String
  listingId      String
  sellerEmail    String?
  activityType   String
  title          String
  description    String?
  impactScore    Int      @default(0)
  metadataJson   Json?
  createdAt      DateTime @default(now())

  @@index([agencyId, listingId, createdAt])
  @@index([sellerEmail])
}

model ValuationComparable {
  id             String   @id @default(cuid())
  agencyId       String
  listingId      String?
  source         String   @default("manual")
  title          String
  city           String
  district       String?
  price          Int
  sizeM2         Float
  rooms          Float?
  pricePerM2     Int
  url            String?
  distanceKm     Float?
  similarityScore Int     @default(50)
  notes          String?
  createdAt      DateTime @default(now())

  @@index([agencyId, city, district])
  @@index([listingId, similarityScore])
}

model DemoRun {
  id            String   @id @default(cuid())
  agencyId      String
  name          String
  targetPersona String   @default("independent_agent")
  status        String   @default("planned")
  stepsJson     Json
  checklistJson Json?
  resultJson    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([agencyId, status, createdAt])
}

model ChatKnowledgeGap {
  id            String   @id @default(cuid())
  agencyId      String?
  listingId     String
  question      String
  safeReply     String
  severity      String   @default("medium")
  status        String   @default("open")
  suggestedFact String?
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?

  @@index([listingId, status, createdAt])
  @@index([agencyId, severity])
}

// V9: white-label, localization, buyer intelligence, chat guardrails, partner API observability, SLA/support.
model AgencyBrandingProfile {
  id             String   @id @default(cuid())
  agencyId       String
  brandName      String
  primaryColor   String   @default("#0f172a")
  accentColor    String   @default("#c8a45d")
  logoUrl        String?
  faviconUrl     String?
  fontFamily     String   @default("Inter")
  publicTone     String   @default("premium_professional")
  footerText     String?
  customCss       String?
  metadataJson   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([agencyId, brandName])
  @@index([agencyId])
}

model WhiteLabelDomain {
  id             String   @id @default(cuid())
  agencyId       String
  domain         String   @unique
  status         String   @default("pending_dns")
  verificationToken String
  verifiedAt     DateTime?
  sslStatus      String   @default("pending")
  metadataJson   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([agencyId, status])
}

model ListingTranslation {
