# V11 launch / enterprise controls
V11_TENANT_ISOLATION_MODE=soft_demo
V11_MONTHLY_AI_BUDGET_HUF=35000
V11_PUBLIC_DEMO_RESET_ENABLED=false
V11_MONITORING_WEBHOOK_URL=
