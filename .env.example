V11_RETENTION_DAYS_RAW_CHAT=180
V11_RETENTION_DAYS_AUDIT=2555

# V12 go-live controls
NEXT_PUBLIC_LISTING_DOMAIN="listings.estatepilot.ai"
V12_ACCEPTANCE_REQUIRED_SCORE="70"
V12_PRODUCTION_REQUIRED_SCORE="88"

# V13 pilot / release operations
RELEASE_COMMIT_SHA=local-dev
PILOT_OWNER_EMAIL=pilot@estatepilot.ai
METERING_CURRENCY=HUF
ENABLE_STRICT_RELEASE_GATES=false
