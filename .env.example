SZAMLAZZ_API_KEY=""

# Analytics / webhook
POSTHOG_KEY=""
WEBHOOK_SECRET=""

# Security / production hardening
SECURITY_HEADERS_ENABLED="true"
API_KEY_SALT="change-me-in-production"
RATE_LIMIT_DRIVER="memory"

# v6 production hardening
AUTH_PROVIDER=dev
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
AUTH_SECRET=
APP_ENV=local
APP_REGION=eu-central-1
SENTRY_DSN=
