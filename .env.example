DATABASE_URL="postgresql://estatepilot:estatepilot@localhost:5432/estatepilot?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
DEFAULT_AGENT_EMAIL="demo@estatepilot.ai"
DEV_AUTH_ENABLED="true"

# AI: üresen hagyva mock/demó outputot ad
OPENAI_API_KEY=""
OPENAI_MODEL_TEXT="gpt-4o-mini"
OPENAI_MODEL_VISION="gpt-4o-mini"

# Email értesítések: üresen hagyva mock logolás történik
RESEND_API_KEY=""
RESEND_FROM_EMAIL="EstatePilot AI <hello@example.com>"

# Storage: MVP-ben local, élesben R2/S3 adapterre cserélhető
STORAGE_DRIVER="local"
STORAGE_PUBLIC_BASE_URL=""
