# EstatePilot AI production env template
NODE_ENV=production
APP_ENV=production
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB
DEFAULT_AGENT_EMAIL=admin@yourdomain.com

# Auth
AUTH_PROVIDER=clerk
AUTH_SECRET=replace_me_32_chars_min
CLERK_SECRET_KEY=replace_me
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=replace_me

# AI
OPENAI_API_KEY=replace_me
OPENAI_MODEL_TEXT=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o-mini

# Storage / CDN
STORAGE_DRIVER=r2
R2_ACCOUNT_ID=replace_me
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET=estatepilot-media
STORAGE_PUBLIC_BASE_URL=https://cdn.yourdomain.com
MAX_UPLOAD_MB=25

# Email
RESEND_API_KEY=replace_me
RESEND_FROM_EMAIL=EstatePilot <noreply@yourdomain.com>

# Billing
STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me
BARION_POS_KEY=replace_me_optional
BARION_ENV=sandbox
SZAMLAZZ_API_KEY=replace_me_optional

# Calendar
GOOGLE_CALENDAR_CLIENT_ID=replace_me
GOOGLE_CALENDAR_CLIENT_SECRET=replace_me
GOOGLE_CALENDAR_REDIRECT_URI=https://app.yourdomain.com/api/calendar/google/callback

# Observability
SENTRY_DSN=replace_me
POSTHOG_KEY=replace_me
WEBHOOK_SECRET=replace_me
ENCRYPTION_KEY=replace_me_32_chars_min
ENABLE_STRICT_RELEASE_GATES=true
# V16 3D / spatial capture provider configuration
THREED_PROVIDER_MODE=mock
THREED_PROVIDER_API_URL=
THREED_PROVIDER_API_KEY=
GAUSSIAN_SPLAT_WORKER_URL=
GAUSSIAN_SPLAT_WORKER_TOKEN=
SPATIAL_ASSET_BUCKET=
SPATIAL_ASSET_CDN_URL=
MOBILE_CAPTURE_DEEP_LINK_BASE=
PANNELLUM_VIEWER_ENABLED=true
SUPER_SPLAT_VIEWER_ENABLED=false

# V21 live 3D / digital twin worker bridge
SPATIAL_WORKER_URL=
SPATIAL_WORKER_TOKEN=
SPATIAL_PROVIDER_MODE=dry_run
